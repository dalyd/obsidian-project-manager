{
	"name": "obsidian-project-manager",
	"version": "0.1.1",
	"description": "Obsidian plugin for managing projects with folder-based organization, automatic archiving, and subproject support.",
	"main": "main.js",
	"repository": {
		"type": "git",
		"url": "https://github.com/dalyd/obsidian-project-manager"
	},
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "vitest run",
		"test:watch": "vitest",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"project-management"
	],
	"author": "David Daly",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^22.0.0",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"builtin-modules": "3.3.0",
		"esbuild": "0.17.3",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "4.7.4",
		"vitest": "latest"
	}
}
